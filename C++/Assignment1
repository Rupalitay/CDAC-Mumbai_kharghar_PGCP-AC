void Student::setMarks(float m) { marks = m; }
void Student::setGrade(char g) { grade = g; }

std::string Student::getName() const { return name; }
int Student::getRollNumber() const { return rollnumber; }
float Student::getMarks() const { return marks; }
char Student::getGrade() const { return grade; }


	void Student :: calculateGrade(){
		this->grade = (marks<=100 && marks>=90) ? 'A':
					  (marks>=80) ? 'B':
		              (marks>=70) ? 'C':
		              (marks>=60) ? 'D':
		                	        'F';
		std::cout<<"Grade calculated\n";
	}

	void Student :: displayInfo(){
		std::cout << "\nName : " << name ;
		std::cout << "\nMarks : " << marks ;
		std::cout << "\nRollNo : " << rollnumber ;
		std::cout << "\nGrade : " << grade;
	}

	void Student :: acceptInfo(){
		std::cin.ignore();
		std::cout<<"Enter the Name : ";
		std::getline(std::cin, name);//getline is used to discard the leftover newline and then read the full line

		std::cout <<"Enter the Marks : ";
		std::cin >> marks;

		std::cout <<"Enter the RollNo : ";
		std::cin >> rollnumber;


