							 Emp.setEmpName(empName);
							 Emp.setEmpSalary(empsalary);
							 break;
						}

			case 2 :   {
						std::cout<<"You entered choice 2. Calculate the gross salary for an employee\n ";

						//To display the gross Salary
						Emp.calculateGrossSalary();
						break;}

			case 3 :	std::cout<<"You have Entered Choice 3. Display Employees details\n";
						Emp.displayEmployeeDetails();break;

