			std::cout << "2. Calculate the gross salary for an employee\n";
			std::cout << "3. Display the Employee details\n";
			std::cout << "4. Update the Employee information.\n";
			std::cout << "5. Exit Program\n";
			std::cin >> choice;

			switch(choice){
			case 1 :    {
							 std::string empName;
							 double empsalary;
				 	 	 	 std::cout << "\nYou Entered choice 1. Add new Employee \n";

				 	 	 	 std::cin.ignore();

				 	 	 	 std::cout<<"\nEnter the new Employee name\n";
				 	 	 	 std::getline(std::cin, empName);

				 	 	 	 std::cout<<"Enter the salary ";
