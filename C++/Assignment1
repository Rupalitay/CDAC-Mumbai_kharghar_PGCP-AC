#include <iostream>
#include <string>

class Employee{
	 static int nextId; //
	 int empID ; //(EmployeeID)
	 std::string empName ;//(Employee-Name)
	 double empSalary ;//(Employee Salary
	 //declaration of variable to calculate the gross Salary
	 double grossSalary;

public:

	 //contructor initialier list
	 Employee(std::string en, double ems)
	 :empName(en),empSalary(ems),grossSalary(0.0){
		 empID = nextId++; //Auto assignment of the employee id
	 }


	 //setters

	 	void setEmpName(const std::string &empName) {
	 		this->empName = empName;
	 	}

	 	void setEmpSalary(double empSalary) {
	 		this->empSalary = empSalary;
	 		calculateGrossSalary(); //auto update the salary of employee
	 	}

	 //getters
	 int getEmpId() const {
	 		return empID;
	 	}

	 	const std::string& getEmpName() const {
	 		return empName;
	 	}

	 	double getEmpSalary() const {
	 		return empSalary;
	 	}

	 //calculate the gross Salary of Employee
	 	void calculateGrossSalary(){

	 		if(empSalary <= 5000 ){
	 			grossSalary = empSalary + (empSalary*0.10);
	 		}
	 		else if(empSalary <= 10000 ){
	 			grossSalary = empSalary + (empSalary*0.15);
	 		}
	 		else grossSalary = empSalary + (empSalary*0.20);

	 		//print the gross salary for the chosen employee
	 		std::cout<<"The gross Salary for the chosen employee is "<<grossSalary<<"\n";
	 	}

	 	//display details of the employee
	 	void displayEmployeeDetails() const{
	 		std::cout<<"Employee ID : "<<empID<<"\n";
	 		std::cout<<"Name of Employee is : "<<empName<<"\n";
	 		std::cout<<"Salary of Employee is  : "<<empSalary<<"\n";
	 		std::cout<<"Gross Salary of Employee is : "<<grossSalary<<"\n";


	 	}


};
int Employee::nextId = 1001;   // starting ID
int main() {
	Employee Emp("abc",0.0);

	int choice;

		do{
			std::cout << "\n---Choice Driven program---\n";
