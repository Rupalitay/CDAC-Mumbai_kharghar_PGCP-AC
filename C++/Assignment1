6.Pointer Swap

#include <stdio.h>

int main() {
	//declare three integer variables
	int x = 10 , y = 20, z = 30;
	// create three pointer pointing to variables
	int *px = &x ;
	int *py = &y;
	int *pz = &z;

	//Print all three variables before the swap
	printf("Before the swap:\n");
	printf("x = %d , y = %d, z = %d \n", x,y,z);
	printf("Addresses of store in pointer:\n");
	printf("px = %p , py = %p, pz = %p \n", px,py,pz);

	//to swap the values of x and z using another variable(temp) and pointers
	int temp = *px;
	*px = *pz;
	*pz = temp;

	//Print all three variables after the swap
	printf("\nAfter the swap:\n");
	printf("x = %d , y = %d, z = %d \n", x,y,z);
	printf("Addresses of store in pointer:\n");
	printf("px = %p , py = %p, pz = %p \n", px,py,pz);

	return 0;
}


7.const Constant in Functions

#include <stdio.h>
//declaration of global variable
const float PI = 3.14159f;

// function returns area of a circle.
float circleArea(float radius){
	float area =  PI * radius * radius;
	return area;
}
//Functon returns circumference of  circle
float circlePerimeter(float radius){
	float circum = 2 * PI * radius;
	return circum;
}

int main() {
	//declaration and initailization of varaible radius
	float radius = 7.0;
	//taking the value form user
	printf("Enter radius of circle : ");
	scanf("%f",&radius);

	//PI = 3.0f; // attempt to modify const //compiler error : assignment of read-only variable 'PI'

	//print the area and circumference of circle
	printf("\nArea of circle : %.4f ",circleArea(radius));
	printf("\nCircumference of circle : %.4f",circlePerimeter(radius));
	return 0;
}


8.(Challenge Absolute value & Clamp - No if-Else)

#include <iostream>
using namespace std;

//function returns the absolute value of n using ternary operator
int absolute(int n){
	return (n>0) ? n : -n ;
}
//function returns the clamp using ternary operator
int clamp(int val, int lo, int hi){
	return  (val < lo) ? lo:
			(val > hi) ? hi:
					val;
}

