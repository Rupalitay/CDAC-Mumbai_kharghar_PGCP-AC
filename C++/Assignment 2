#include <iostream>
#include <string>
using namespace std;
class Student{

	string name;
	int rollnumber = 0;
	float marks = 0.0f;


public:
	// Constructors
    Student(){}

    Student(string name,int rollnumber ,float marks ){
    this-> name = name;
	this-> rollnumber = rollnumber;
	this-> marks = marks;

    }

    // display or print output on console
	void displayInfo(){
	    cout<<"Name : "<<this->name<<endl;
	    cout<<"Rollnumber : "<<this->rollnumber<<endl;
	    cout<<"Marks : "<<this->marks<<endl;
	}


};

int main(){
	Student S;
	Student S1("Mooni",34,76.8);
	Student S2("falguni",10,89.8);

	S.displayInfo();cout<<"\n";
	S1.displayInfo();cout<<"\n";
	S2.displayInfo();
	return 0;
}

