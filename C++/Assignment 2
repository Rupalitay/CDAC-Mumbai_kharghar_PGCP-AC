#include <iostream>
using namespace std;

class Box{
	int length , width, height;
public:
	Box(){
		length = 0.0; width = 0.0; height = 0.0;
	}
	Box(int length , int width, int height){
		this->length = length;
		this->width = width;
		this->height = height;
	}

	void setDimensions(int l, int w, int h){
		this->length = l;this->width = w; this->height=h;
	}
	void volume(){
		int vol = 0;
		vol = this->length * this->width * this->height;
		cout<< "volume is "<<vol<<endl;
	}
};

int main() {

	Box B;
	Box B1(34.5,67.4,34.0);

	B.setDimensions(1.0, 0.0, 6.0);
	B1.setDimensions(4.5, 3.4, 4.0);
	B.volume();
	B1.volume();


	return 0;
}


