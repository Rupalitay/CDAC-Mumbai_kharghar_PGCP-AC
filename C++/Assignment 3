/*---------------------------------------------------------------------------------------------

#include <iostream>
using namespace std;

class Employee{
	int * id;
	string name;
	mutable int accessCount;

public:

	Employee(int i,string n){
		accessCount = 0;
		id = new int(i) ;
		name = n;
		cout<<"Default Constructor.."<<endl;

	}

	Employee(const Employee& E){
		//Shallow Copy
		this->id = E.id;
		
		name = E.name;
		accessCount = E.accessCount;
		
		//Shallow Copy
		this->id = E.id;

		//DEEP COPY
		id = new int(*E.id);
		cout<<"Default copy Constructor by Deep copy .."<<endl;
	}

	void display() const{
		accessCount++;
		cout<<"ID: "<<*id<<" Name: "<<name<<" AccessCount: "<<accessCount<<endl;

	}
	~Employee(){
		delete id;
	}

};

int main(){
	Employee e1(23,"Harry");
	e1.display();
	e1.display();
	e1.display();

	Employee e2 = e1;
  
	return 0;
}

