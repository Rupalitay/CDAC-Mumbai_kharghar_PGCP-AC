4. Try and Catch

#include<iostream>
using namespace std;
class DivideByZeroException{
public:
	const char* mess(){
		return "Error: Division by zero is not allowed"
	}
};
int main(){
	int num, den;

	cout<<"Enter numerator: ";
	cin>>num;

	cout<<"Enter numerator: ";
	cin>>den;

	try{

		if(den == 0){
		throw DivideByZeroException();//throw custom exception
		}
		try{
				throw"Inner throw";
		}catch(const char* ms){
			cout<<"Inner Inner Catch"<<endl;
			throw;
			cerr<<"Inner Catch"<<ms<<endl;
		}
		cout<<"Result = "<< num/den <<endl;
	}catch(DivideByZeroException e){
        cout<< e.mess()<<endl;
    }
	return 0;
}

