1. Grade Calculator


#include <stdio.h>

int main() {
	float english_marks, maths_marks, science_marks, hindi_marks, computer_marks, total, percentage;
	const char *grade;//Pointer to string
	printf("Enter the marks of English, Mathematics, Science, Hindi and Computer out of 100\n");
	scanf("%f %f %f %f %f",&english_marks, &maths_marks, &science_marks, &hindi_marks, &computer_marks);

	total = (english_marks + maths_marks + science_marks + hindi_marks + computer_marks);
    printf("Total : %.2f\n",total);

	percentage = (total/500)*100 ;
    printf("Percentage : %.2f\n",percentage);

    grade = (percentage>=75) ? "A":
    		(percentage>=60) ? "B":
    		(percentage>=45) ? "C":
    						"Fail";
    printf("Grade : %s\n",grade);
	return 0;
}

Output:-
				Enter the marks of English, Mathematics, Science, Hindi and Computer out of 100
				89 98 87 79 88
				Total : 441.00
				Percentage : 88.20
				Grade : A


