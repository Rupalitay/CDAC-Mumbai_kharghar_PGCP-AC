6.Pointer Swap

#include <stdio.h>

int main() {
	//declare three integer variables
	int x = 10 , y = 20, z = 30;
	// create three pointer pointing to variables
	int *px = &x ;
	int *py = &y;
	int *pz = &z;

	//Print all three variables before the swap
	printf("Before the swap:\n");
	printf("x = %d , y = %d, z = %d \n", x,y,z);
	printf("Addresses of store in pointer:\n");
	printf("px = %p , py = %p, pz = %p \n", px,py,pz);

	//to swap the values of x and z using another variable(temp) and pointers
	int temp = *px;
	*px = *pz;
	*pz = temp;

	//Print all three variables after the swap
	printf("\nAfter the swap:\n");
	printf("x = %d , y = %d, z = %d \n", x,y,z);
	printf("Addresses of store in pointer:\n");
	printf("px = %p , py = %p, pz = %p \n", px,py,pz);

	return 0;
}

Output:-
			Before the swap:
			x = 10 , y = 20, z = 30 
			Addresses of store in pointer:
			px = 0x7ffe88ec81f0 , py = 0x7ffe88ec81ec, pz = 0x7ffe88ec81e8 
			
			After the swap:
			x = 30 , y = 20, z = 10 
			Addresses of store in pointer:
			px = 0x7ffe88ec81f0 , py = 0x7ffe88ec81ec, pz = 0x7ffe88ec81e8 
	

