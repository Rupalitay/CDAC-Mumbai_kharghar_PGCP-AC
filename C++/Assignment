8.(Challenge Absolute value & Clamp - No if-Else)


#include <iostream>
using namespace std;

//function returns the absolute value of n using ternary operator
int absolute(int n){
	return (n>=0) ? n : -n ;
}
//function returns the clamp using ternary operator
int clamp(int val, int lo, int hi){
	return  (val < lo) ? lo:
			(val > hi) ? hi:
					val;
}

int main() {

	// Given test cases in  array
	    int val[] = {-15, 0, 25, -3};
	    int lo[]  = {-10, -10, -10, 0};
	    int hi[]  = { 10,  10,  10, 5};

	    //print output on console
	    cout << "val\tlo\thi\tabsolute(val)\tclamp(val, lo, hi)\n";

	    for(int i = 0; i < 4; i++) {
	    	cout << "----------------------------------------------------------\n";

	        cout << val[i] << "\t"
	             << lo[i] << "\t"
	             << hi[i] << "\t"
	             << absolute(val[i]) << "\t\t"
	             << clamp(val[i], lo[i], hi[i]) << endl;
	    }

	return 0;
}

