//11. Count Positive and Negative Numbers in an Array


import java.util.Scanner;
import java.util.Arrays;
class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter 6 integers : ");
        int[] arr = new int[6]; 
        for (int i = 0; i < 6; i++) {
            if (sc.hasNextInt()) {
                arr[i] = sc.nextInt();
            }
        }
        System.out.println(" ");
        int PositiveCount = 0;
        int NegativeCount = 0;
        for(int j = 0; j < 6; j++){
            if(arr[j]>0)
            {
                PositiveCount++;
            }
            if(arr[j]<0)
            {
                NegativeCount++;
            }
            
        }
        System.out.println("Positive Numbers  :  " + PositiveCount);
        System.out.println("Negative Numbers  :  " + NegativeCount);    
        // Close the scanner
        sc.close();
    }
}


