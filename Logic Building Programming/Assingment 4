//15.Write a Program to print the Following pattern


class Main {
    public static void main(String[] args) {
        for(int i=1 ; i<=5 ; i++){
            if(i>1){
                for(int j=1 ; j<i ;j++){
                     System.out.println(i + "*");
                }
            }
             System.out.println(i);
        }
        for(int i=5 ; i>1 ; i--){
            if(i>1){
                for(int j=1 ; j<i ;j++){
                     System.out.println(i + "*");
                }
            }
             System.out.println(i);
        }
    }
}


