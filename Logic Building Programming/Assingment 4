//13.Check if an Array Contains a Specific Element


import java.util.Scanner;
import java.util.Arrays;
class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter 5 integers : ");
        int[] arr = new int[5]; 
        for (int i = 0; i < 5; i++) {
            if (sc.hasNextInt()) {
                arr[i] = sc.nextInt();
            }
        }
        System.out.println(" ");
        Arrays.asList(arr);
        int numbersearch = 0;
        System.out.println("Enter the number to search :  "); 
        numbersearch = sc.nextInt();
        System.out.println(" ");
        int j=0;
        int count = 0;
        for (j=0 ; j<5 ; j++){
            if(numbersearch == arr[j]){
                count++;
                System.out.println("Found");
                break;
            }
        }
        if(count == 0){
                System.out.println("Not Found");
            }
        // Close the scanner
        sc.close();
    }
}


