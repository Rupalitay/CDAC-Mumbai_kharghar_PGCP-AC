//1.Print Numbers from 1 to N

import java.util.Scanner;
class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter a number : ");
        int N = sc.nextInt();
        System.out.println("");
        for(int i = 1;i<=N;i++){
            System.out.println(i);
        }
    }
}

