import java.util.Arrays;
class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter 5 integers : ");
        int[] arr = new int[5]; 
        for (int i = 0; i < 5; i++) {
            if (sc.hasNextInt()) {
                arr[i] = sc.nextInt();
            }
