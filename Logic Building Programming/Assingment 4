//6.Print All Elements of an Array

import java.util.Scanner;
class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter 5 integers : ");
        int[] arr = new int[5]; 
        for (int i = 0; i < 5; i++) {
            if (sc.hasNextInt()) {
                arr[i] = sc.nextInt();
            }
        }
        System.out.println(" ");
        for (int element : arr) {
            System.out.println(element);
        }

        // Close the scanner
        sc.close();
    }
}

//7.Find the sum of All Elements in an Array
import java.util.Scanner;
class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter 5 integers : ");
        int[] arr = new int[5]; 
        for (int i = 0; i < 5; i++) {
            if (sc.hasNextInt()) {
                arr[i] = sc.nextInt();
            }
        }
        System.out.println(" ");
        int sum = 0;
        for (int element : arr) {
            sum = sum + element;
        }
        System.out.println("The sum of all numbers is : " + sum);
        // Close the scanner
        sc.close();
    }


