//1. Grade Evaluation System


public class StudentAverageandGradeCalculator{
    public static void main(String[] args) {
    //perdefined values
        int Mathsmarks = 80;
        int Sciencemarks = 85;
        int Historymarks = 90;
    // Calculate Average
        int Average = (Mathsmarks+Sciencemarks+Historymarks)/3;
        String grade;
        
        if(Average>=90){
            grade = "A";
        }
        else if(Average>=70){
            grade = "B";
        }
        else if(Average>=50){
            grade = "C";
        }
        else if(Average>=30){
            grade = "D";
        }
        else{
            grade = "fail";
        }
    
        // Output Results
        System.out.println("Average Marks: " + Average);
        System.out.println("Grade: " + grade);
    }
}


//2.Leap Year

class LeapYear {
    public static void main(String[] args) {
        // predefined values 
        int year1 = 2024;
        int year2 = 1900;
        if(year1%4==0){
            if (year1%100!=0 || year1%400==0){
            System.out.println(year1+" is a Leap year");
            }
        else {    
            System.out.println(year1+" is a not Leap year");
        }
        }
        else{
              System.out.println(year1
              +" is a not Leap year");
        } 
        
        if(year2%4==0){
            if (year2%100!=0 || year2%400==0){
                  System.out.println(year2+" is a Leap year");
            }
             else{
              System.out.println(year2+" is a not Leap year");
        }
        }    
        else{
              System.out.println(year2+" is a not Leap year");
        }
        
    }    
}

