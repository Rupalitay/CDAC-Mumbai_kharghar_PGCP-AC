package Assignment.A1;
import java.util.*;

public class Fibonnacii {
	static int fibo(int a ) {
		int ab = 0;
		if(a>= 0) {
			if(a == 0 ||a == 1) {
				return a;
			}
			else {
				ab = fibo(a-1) + fibo(a-2);
				return ab;
			}
		}
		return -1;
	}	
	public static void main(String args[]) {
		Scanner sc = new Scanner(System.in);
		int n = sc.nextInt();
		System.out.println(fibo(n));
		
		sc.close();
	}
}

