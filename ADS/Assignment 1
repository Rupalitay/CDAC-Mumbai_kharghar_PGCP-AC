package Assignment;

public class Factorial {
	static int fact(int a ){
		if(a >= 0) {
			if(a == 0) {
				return 1;
			}
			else {
				return a * fact(a-1);
				} 
		}
		else {
			System.out.println("Number is less than 0");
			return -1;
		}
	}
	public static void main(String[] args) {
		System.out.println(fact(2));
	}

}

