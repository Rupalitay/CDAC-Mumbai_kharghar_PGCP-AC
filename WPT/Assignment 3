<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Highlight Bold Words</title>
    <script>
        // Global variable to store bold elements
        var bold_Items;

        // Function to collect all bold elements when the page loads
        window.onload = function() {
            bold_Items = document.getElementsByTagName('strong');
        };

        // Function to highlight bold words (change color to blue or any color)
        function highlight() {
            for (var i = 0; i < bold_Items.length; i++) {
                bold_Items[i].style.color = "blue";
                bold_Items[i].style.backgroundColor = "yellow"; // Optional highlight
            }
        }

        // Function to return words to normal state
        function return_normal() {
            for (var i = 0; i < bold_Items.length; i++) {
                bold_Items[i].style.color = "black";
                bold_Items[i].style.backgroundColor = "transparent";
            }
        }
    </script>
</head>
<body>
    <!-- The link with mouse events -->
    <p>
        [<a href="#" onmouseover="highlight()" onmouseout="return_normal()">
            On mouse over here bold words of the following paragraph will be highlighted
        </a>]
    </p>

    <!-- The paragraph containing bold words -->
    <p>
        <strong>We</strong> have just started <strong>this</strong> section for the users 
        (<strong>beginner</strong> to intermediate) who <strong>want</strong> to work with 
        <strong>various</strong> JavaScript <strong>problems</strong> and write scripts 
        online to <strong>test</strong> their JavaScript <strong>skill</strong>.
    </p>

    
</body>
</html>
