<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>User Information Form</title>
</head>
<body>

    <h2>Registration Form</h2>
    <!-- Form creation -->
    <form id="userForm">
        <div class="form-group">
            <label for="firstName">First Name:</label>
            <input type="text" id="firstName" required>
        </div>
        <br><br>
        <div class="form-group">
            <label for="lastName">Last Name:</label>
            <input type="text" id="lastName" required>
        </div>
        <br><br>
        <div class="form-group">
            <label for="contactNo">Contact No.:</label>
            <input type="tel" id="contactNo" required>
        </div>
        <br><br>
        <div class="form-group">
            <label for="emailId">Email ID:</label>
            <input type="email" id="emailId" required>
        </div>
        <br><br>
        <button type="button" onclick="displayFormValues()">Submit</button>
    </form>

    <!-- Area to print values -->
    <div id="displayArea" style="display:none;">
        <h3>Submitted Values:</h3>
        <p id="result"></p>
    </div>

    <script>
        // JavaScript function to get and print values
        function displayFormValues() {
            // Getting values from the form
            const firstName = document.getElementById('firstName').value;
            const lastName = document.getElementById('lastName').value;
            const contactNo = document.getElementById('contactNo').value;
            const emailId = document.getElementById('emailId').value;

            // Simple check to ensure fields aren't empty
            if(firstName && lastName && contactNo && emailId) {
                const resultDiv = document.getElementById('displayArea');
                const resultText = document.getElementById('result');

                // Printing values to the browser page
                resultText.innerHTML = `
                    <strong>First Name:</strong> ${firstName} <br>
                    <strong>Last Name:</strong> ${lastName} <br>
                    <strong>Contact No:</strong> ${contactNo} <br>
                    <strong>Email ID:</strong> ${emailId}
                `;
                
                resultDiv.style.display = 'block';
            } else {
                alert("Please fill out all fields.");
            }
        }
    </script>

</body>
</html>

