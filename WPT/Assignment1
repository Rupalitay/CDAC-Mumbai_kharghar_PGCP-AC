    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
}
.social-container{
    margin: 20px;
    display: flex;
    justify-content: center;
    gap: 10px;
}

.social-container a{
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    height: 40px;
    width: 40px;
    text-decoration: none;
    color: white;
    font-size: 18px;
    transition: all 0.3s ease;
}

 .social-container a:hover {
    color: #667eea;
    border-color: white;
    background-color: white;
}

h1 {
    font-weight: bold;
    margin: 0 0 20px 0;
    font-size: 32px;
}

p{
    font-size: 14px;
    font-weight: 100;
    line-height: 20px;
    letter-spacing: 0.5px;
    margin: 20px 0 30px;
}

label{

    font-size: 14px;
    font-weight: 500;
    margin: 15px 0 15px;
    display: block;
    color: rgb(39, 35, 35);

}

button{
    border-radius: 20px;
    border: 1px solid rgb(119, 119, 227);
    background-color: rgb(151, 187, 234);
    color: aliceblue;
    font-size: 12px;
    font-weight: bold;
    padding: 12px 45px;
    letter-spacing: 1;
    text-transform: uppercase;
    transition: transform 80ms ease-in, all 0.3s ease;
    cursor: pointer;
    margin-top: 20px;
}
button:hover{
    transform:translateY(-2px) ;
}

input{
    background-color: azure;
    border: none;
    padding: 12px 15px;
    margin: 8px 0;
    width: 100%;
    border-radius: 5px;
    transition: all 0.3s ease;
}

input:focus{
    outline: none;
    background-color: #fff;
    border: 2px solid blue;
}

input::placeholder{
    color: #999;
    font-size: 14px;
}
.form-control a {
    color: #04145b;
    text-decoration: none;
    font-size: 12px;
    transition: color 0.3s ease;
}

.form-control a:hover {
    color: #cfd7da;
    text-decoration: underline;
}
.social-icon{
    display: inline-block;
    width: 20px;
    height: 20px;
