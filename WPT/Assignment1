.container {
    display: flex;
    height: 100vh;
}

.left-column {
    flex: 0 0 35%;
    background: linear-gradient(180deg, #2C5282 0%, #4A90E2 50%, #63B3ED 100%);
    color: white;
    padding: 50px 30px;
    position: relative;
}

.left-column h1 {
    font-size: 40px;
    font-weight: 600;
    margin-bottom: 50px;
}

.info-item {
    display: flex;
    align-items: center;
    margin-bottom: 35px;
}

.info-item i {
    font-size: 20px;
    margin-right: 20px;
    width: 24px;
    text-align: center;
    opacity: 0.9;
}

.info-text .label {
    font-size: 13px;
    opacity: 0.7;
    display: block;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.info-text .value {
    font-size: 16px;
    font-weight: 500;
    margin-top: 2px;
}

.social-icons {
    display: flex;
    gap: 20px;
    position: absolute;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%);
}

.social-icons a {
    color: white;
    font-size: 18px;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.3s ease;
}

.social-icons a:hover {
    opacity: 1;
}

.decorative-shapes {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    overflow: hidden;
}

.circle-1 {
    position: absolute;
    width: 120px;
    height: 120px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    bottom: 30px;
    left: 30px;
}

.circle-2 {
    position: absolute;
    width: 80px;
    height: 80px;
    background: rgba(255, 182, 193, 0.4);

    bottom: 60px;
    left: 140px;
}

.circle-3 {
    position: absolute;
    width: 50px;
    height: 50px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    bottom: 40px;
    right: 60px;
}

.triangle-1 {
    position: absolute;
    width: 0;
    height: 0;
    border-left: 80px solid transparent;
    border-right: 80px solid transparent;
    border-bottom: 120px solid rgba(173, 216, 230, 0.6);
    bottom: 0;
    right: 0;
    transform: rotate(45deg);
}

.triangle-2 {
    position: absolute;
    width: 0;
    height: 0;
    border-left: 70px solid transparent;
    border-right: 70px solid transparent;
    border-bottom: 100px solid rgba(255, 182, 193, 0.7);
    bottom: 0;
    left: 0;
    transform: rotate(-45deg);
}

.right-column {
    flex: 0 0 65%;
    background: white;
    padding: 50px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100vh;
}

.right-column h1 {
    font-size: 36px;
    color: #333;
    margin-bottom: 40px;
    text-align: center;
    font-weight: 600;
}

.contact-form {
    max-width: 100%;
    margin: 0 auto;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.form-group {
    margin-bottom: 20px;
}

.form-group input,
.form-group textarea {
    width: 100%;
    padding: 15px;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-size: 14px;
    transition: border-color 0.3s ease;
    background: #f8f9fa;
}

.form-group input:focus,
.form-group textarea:focus {
    outline: none;
    border-color: #4A90E2;
    background: white;
}

.form-group textarea {
    min-height: 120px;
    resize: vertical;
}

.submit-btn {
    width: 100%;
    padding: 15px;
    background: #4A90E2;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
}

.submit-btn:hover {
    background: #357ABD;
}

