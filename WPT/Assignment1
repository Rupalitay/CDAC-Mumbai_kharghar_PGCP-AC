    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    overflow: hidden;
}

.container{
    background-color: white;
    border-radius: 100px;
    position: relative;
    overflow: hidden;
    width: 768px;
    max-width: 100%;
    min-height: 480px;
    transition: all 0.3s ease;
    display: flex;
}

.sign-division{
    background:linear-gradient(to right, rgb(97, 97, 219),rgb(64, 161, 202)) ;
    color: white;
