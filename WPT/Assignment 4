    </head>
    <body>
        <script>
            function multiply(element, index){
                console.log("index : "+index+ ", Element multiply by 2: " +element*2);
            }            
            
            function forEachElement(arr, callback){
                for(let i = 0; i<arr.length;i++){
                    callback(arr[i],i);
                }
            }

            let array = [3,3,4,5,6,7,6];
            console.log(array);
            forEachElement(array,multiply);
        </script>
    </body>
</html>

