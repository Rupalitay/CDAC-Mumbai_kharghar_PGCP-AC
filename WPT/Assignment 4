<html>
    <head>
        <title>Exercise5</title>
    </head>
    <body>
        <script>
            function fetchData(url,callback){
                setTimeout(()=>{
                    let iserror = false;
                    if(iserror){
                        callback(`Error: Invalid ${url} url `,null);
                    }else{
                        const response = `Response form ${url}: Data fetched sucessfully`;
                        callback(null,response);
                    }
                    
                },2000);
            }

            function processData(data, callback){
                setTimeout(()=>{
                    const processedResult = `${data} - processed sucessfully`;
                    callback(processedResult);
                },1000);
            }

            fetchData("https://google.com",(error,result)=>{
                if(error){
                    console.error("Fetch Error: ",error);
                }else{
                    console.log("Fetched: ",result);
                    
                    processData(result,(finalOutput)=>{
                        console.log("Final Result: ",finalOutput);
                    });
                }
            });
            
        </script>
    </body>
</html>
