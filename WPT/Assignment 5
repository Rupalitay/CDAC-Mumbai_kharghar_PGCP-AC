<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Movie</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700&display=swap" rel="stylesheet">
        <style>
            body{
                font-family: 'Inter',sans-serif;
                background: radial-gradient(circle at top right, rgba(60, 188, 216, 0.938), transparent);
                transition: all 0.3s ease;
            }

            .hero-section{
                padding: 60px 0;
            }

            .movie-card{
                border: 1px solid rgb(47, 44, 44);
                border-radius: 20px;
                overflow: hidden;
                transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                height: 100%;
                position: relative;
            }

            .movie-card:hover{
                transform: translateY(-10px);
                border-color: black;
                box-shadow: 0 15px 30px rgb(42, 40, 40);
            }

            .poster-wrapper{
                position: relative;
                height: 400px;
            }

            .poster-img{
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .card-body{
                padding: 1.25rem;
            }

            .movie-title{
                font-weight: 700;
                font-size: 1.1rem;
                margin-bottom: 5px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .movie-meta{
                color: grey;
                font-size: 0.85rem;
            }

            #loader .spinner-border{
                width: 3rem;
                height: 3rem;
                color: rgb(106, 103, 103);
            }

        </style>
    </head>
    <body >
        <div class="container hero-section text-center py-5">
            <!-- heading section -->
            <h1 class="display-4 fw-bold mb-3">Cine<span style="color:#173ccf">Lens</span></h1>
            <!-- Add your tagline here -->
            <p class="text-muted mb-5 fs-4">
                Your ultimate movie discovery platform.
            </p>
            <div class="row justify-content-center">
                <div class="col-md-7 mx-auto mb-3">
                    <div class="input-group">
                        <input type="text" id="searchInput" class="form-control search-pill" placeholder="Search for movies (e.g. Batman, Avengers).......">
                        <button id="searchBtn" class="btn btn-primary ">Search</button>
                    </div>
                </div>
            </div>
            <div class="container pb-5">
                <div id="loader" class="text-center d-none my-5">
                    <div class="spinner-border" role="status"></div>
                    <p class="mt-3 text-muted">Lights, Camera, Action...</p>
                </div>
                <div id="resultsContainer" class="row g-4"></div>
            </div>
        </div>

        <script>
            //activation for api key
            const API_KEY = 'a2666671dfb4fda3c8e4e3e1980aa656'; 

            const searchInput = document.getElementById("searchInput");
            const resultsContainer = document.getElementById("resultsContainer");
            const loader = document.getElementById("loader");

            searchInput.addEventListener("keypress",(ev)=>{
                if(ev.key === "Enter"){
                    const query = searchInput.value.trim();
                    if(query){
                        fetchMovies(query);
                    }
                }
            });

            async function fetchMovies(query) {
                loader.classList.remove("d-none");
                resultsContainer.innerHTML = "";

                try{
                    const url = `https://api.themoviedb.org/3/search/movie?api_key=${API_KEY}&query=${encodeURIComponent(query)}&include_adult=false`;
                    const response = await fetch(url);
                    const data = await response.json();

                    if(!data.results || data.results.length === 0){
                        resultsContainer.innerHTML = `<div class="col-12 text-center text-muted">No Movies found for "${query}"</div>`
                    }else{
                        getMovies(data.results);
                    }
                }catch(error){
                    console.error("Fetch Error: ",error);
                    resultsContainer.innerHTML = `<div class="col-12 text-center text-muted">Error connecting to the movie database.</div>`
                }finally{
                    loader.classList.add("d-none");
                }
            }

            function getMovies(movies){
                movies.forEach(movie =>{
                    const col = document.createElement("div");
                    col.className = "col-sm-6 col-md-4 col-lg-3";

                    const posterPath = movie.poster_path
                    ? `https://image.tmdb.org/t/p/w500${movie.poster_path}` 
                    : 'https://via.placeholder.com/500x750?text=No+Poster+Found';

                    const releaseYear = movie.release_date
                    ? movie.release_date.split("-")[0]
                    :"N/A";

                    col.innerHTML = `
                        <div class="movie-card">
                            <div>
                                <img src="${posterPath}" class="poster-img" alt="${movie.title}" loading="lazy">
                            </div>
                            <div class="card-body">
                                <div class="movie-title" title="${movie.title}">${movie.title}</div>
                                <div class="movie-meta">${releaseYear}•Movie</div>
                            </div>
                        </div>
                    `;

                    resultsContainer.appendChild(col);
                })
            }

        </script>
    </body>
</html>
