function processNumbers(nums) {
  return nums
    .filter(num => num % 2 === 0)   // Keep only even numbers
    .map(num => num * 2)            // Double those numbers
    .reduce((acc, curr) => acc + curr, 0); // Sum them up
}

const numbers = [1, 2, 3, 4, 5, 6];
console.log(processNumbers(numbers)); // Output: 24 (4 + 8 + 12)

