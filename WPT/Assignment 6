function fetchInitialExpenses(){
    return new Promise((resolve) => {
        setTimeout(()=>{
            resolve([
                {description: "Groceries" , amount: 100, date:"2026-04-28"},
                {description: "Milk" , amount: 60, date:"2026-04-28"},
                {description: "Vegetables" , amount: 70, date:"2026-04-27"},
                {description: "Toy" , amount: 600, date:"2026-04-27"},
                {description: "Bottle" , amount: 200, date:"2026-04-26"}
            ]);
        },1000);
    });
}

function createTracker(){

    let expense = [];
    return{
         addExpenses:(callback , ...newExpenses)=>{
            expense = [...expense,...newExpenses];
            callback("Expenses added sucessfully!");
        },
        getExpenses: () => expense
    };
}

const tracker = createTracker();

const displayDetails = ({description,amount,date}) => {
    console.log(`${date}: ${description} - Rs.${amount}`);
}

const processExpenses = (expenseList) =>{
    console.log("----All Descriptions----");
    const description = expenseList.map(exp => exp.description);
    console.log(description);

    console.log("----Expenses Greater than 100----");
    const expenseListgreaterthan100 = expenseList.filter(exp => exp.amount > 100);
    console.log(expenseListgreaterthan100);

    const total = expenseList.reduce((sum,exp) => sum + exp.amount, 0);
    console.log(`Total Expenses: Rs.${total}`);

}

const successMessage = (msg) => console.log(`[Notification]: ${msg}`);

async function personalBudgetTracker() {
    console.log("Loading initial data..");
    const initialdata = await fetchInitialExpenses();

    tracker.addExpenses(successMessage,...initialdata);

    const newItem = {description:"Internet Bill", amount: 350, date: "2026-04-28"};
    tracker.addExpenses(successMessage,newItem);

    const currentExpenses = tracker.getExpenses();
    console.log("--Expenses log..");
    currentExpenses.forEach(displayDetails);
    processExpenses(currentExpenses);

}
personalBudgetTracker();


