const TAX_RATE = 0.08;
const CURRENCY = "RS."

var storeName = "Quick Shop"

let cartItems = [];
let totalSubtotal = 0;

function addItem(name,price){
    cartItems.push({name,price});
    totalSubtotal += price;
    console.log(`Added ${name} to cart.`);   
}

addItem("Milk",60);
addItem("Bread",50);
addItem("Sugar",40);

let taxAmount = totalSubtotal * TAX_RATE;
let finalTotal = totalSubtotal + taxAmount;

console.log("----Receipt----");
console.log("Store: ",storeName);
console.log("Items: ",cartItems.length);
console.log("Subtotal: ", CURRENCY + totalSubtotal);
console.log("Tax: ",CURRENCY+taxAmount);
console.log("Total: ",CURRENCY+finalTotal);
