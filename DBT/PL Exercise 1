5. Write a program that enables a user to input an integer. The program should then 
state whether the integer is evenly divisible by 5.    


DELIMITER //
CREATE PROCEDURE PCA5(X INT)
BEGIN 
	IF X%5 = 0 THEN 
		INSERT INTO TEMC VALUES (X, 'IS DIVISIBLE BY 5');
    ELSE 
		INSERT INTO TEMC VALUES(X, 'IS NOT DIVISIBLE BY 5');
    END IF;    
END; //
DELIMITER ;


mysql> CALL PCA5(6);
Query OK, 1 row affected (0.099 sec)

mysql> CALL PCA5(20);
Query OK, 1 row affected (0.198 sec)

mysql> SELECT * FROM TEMC;
