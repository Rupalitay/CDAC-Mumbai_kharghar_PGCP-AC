4. Convert a number of inches into yards, feet, and inches. For example, 124 inches 
equals 3 yards, 1 foot, and 4 inches.    


DELIMITER //
CREATE PROCEDURE PA4()
BEGIN 
	DECLARE INC INT DEFAULT 124;
    DECLARE YARDS INT;
    DECLARE FOOT INT;
    DECLARE INCE INT;
    DECLARE REM INT;
    
    SET YARDS = INC / 36;
    SET REM = INC % 36;
    SET FOOT = REM / 12;
    SET INCE = REM % 12;
    
    SELECT YARDS , FOOT , INCE ;
END; //
DELIMITER ;    



mysql> CALL PA4();
+-------+------+------+
| YARDS | FOOT | INCE |
+-------+------+------+
|     3 |    1 |    4 |
+-------+------+------+
1 row in set (0.118 sec)

