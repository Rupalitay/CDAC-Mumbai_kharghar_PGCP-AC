2. Write a program that declares an integer variable called num, assigns a value to it, 
and computes and inserts into the tempp table the value of the variable itself, its 
square, and its cube.     

DELIMITER //
CREATE PROCEDURE PA2()
BEGIN 
	DECLARE NUM INT ;
    DECLARE SQU INT;
    DECLARE CUB INT;
    SET NUM = 10;
    SET SQU = NUM * NUM;
    SET CUB = NUM * NUM * NUM;
    INSERT INTO TEMPP VALUES (SQU , CUB);
END; //
DELIMITER ;  

CALL PA2();



mysql> SELECT * FROM TEMPP;
+-------+--------+
| FIRST | SECOND |
+-------+--------+
|   100 |   1000 |
+-------+--------+


