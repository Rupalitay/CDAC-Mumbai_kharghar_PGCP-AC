1. Write a program that computes the perimeter and the area of a rectangle. Define 
your own values for the length and width. (Assuming that L and W are the length 
and width of the rectangle, Perimeter = 2*(L+W) and Area = L*W.    

CREATE TABLE TEMPP
(
FIRST FLOAT,
SECOND FLOAT
);


DELIMITER //
CREATE PROCEDURE PA1()
BEGIN 
DECLARE L FLOAT  DEFAULT 24;
DECLARE W FLOAT  DEFAULT 32;
DECLARE PER FLOAT ;
DECLARE AREA FLOAT;
SET PER = 2 * ( L + W);
SET AREA = L * W;
INSERT INTO TEMPP VALUES(PER, AREA);
END; //
DELIMITER ;

CALL PA1();

SELECT * FROM TEMPP;

mysql> SELECT * FROM TEMPP;
+-------+--------+
| FIRST | SECOND |
+-------+--------+
|   112 |    768 |
+-------+--------+
1 row in set (0.010 sec)


