3. Convert a temperature in Fahrenheit (F) to its equivalent in Celsius (C) and vice 
versa. The required formulae are:-  C= (F-32)*5/9    
F= 9/5*C + 32    


DELIMITER //
CREATE PROCEDURE PA3(C FLOAT , F FLOAT )
BEGIN
	DECLARE FAH FLOAT;
    DECLARE CAL FLOAT;
    SET CAL = (F - 32)*5/9;
    SET FAH = 9/5 * C + 32;
    INSERT INTO TEMPP VALUES(FAH ,CAL);
END ; //
DELIMITER ;  

mysql> CALL PA3(34.3,98.34);
Query OK, 1 row affected (0.105 sec)

