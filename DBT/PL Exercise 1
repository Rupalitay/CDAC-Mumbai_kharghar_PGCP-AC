6. Your block should read in two real numbers and tell whether the product of the two 
numbers is equal to or greater than 100. 


DELIMITER //
CREATE PROCEDURE PA6(X INT, Y INT )
BEGIN 
	DECLARE TEMP INT;
	SET TEMP = X * Y;
	IF TEMP> 100 THEN 
		INSERT INTO TE VALUES (X ,Y, 'PRODUCT IS GREATER THAN 100');
    ELSEIF TEMP = 100 THEN
		INSERT INTO TE VALUES (X ,Y, 'PRODUCT IS EQUAL TO 100');
    ELSE 
		INSERT INTO TE VALUES(X, Y, 'PRODUCT IS LESS THEN 100');
    END IF;    
END; //
DELIMITER ;

