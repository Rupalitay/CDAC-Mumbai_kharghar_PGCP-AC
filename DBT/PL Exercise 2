3. Check if a given a year is a leap year. The condition is:- year should be (divisible by 4 
and not divisible by 100) or (divisible by 4 and divisible by 400.). The year should be 
Selected from some table.    

DELIMITER //
CREATE PROCEDURE PA23()
BEGIN
	DECLARE X INT ;
    SELECT FIRST INTO X
    FROM T3INT
    LIMIT 1  OFFSET 5;
    
    IF  (X % 4 = 0 AND X % 100 = 0) OR (X % 4 = 0 AND X % 400 = 0)
    THEN 
		INSERT INTO TEMC VALUES(X,'LEAP YEAR');
    ELSE 
		INSERT INTO TEMC VALUES(X,'NOT LEAP YEAR');
    END IF;
END; //
DELIMITER ;

mysql> CALL PA23();
Query OK, 1 row affected (0.066 sec)

mysql> SELECT * FROM TEMC;
+-------+---------------+
| FIRST | SECOND        |
+-------+---------------+
|  2020 | NOT LEAP YEAR |
+-------+---------------+
1 row in set (0.007 sec)

