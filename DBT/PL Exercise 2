2. Select from any table three positive integers representing the sides of a triangle, and 
determine whether they form a valid triangle. Hint: In a triangle, the sum of any two 
sides must always be greater than the third side.      

delimiter //
CREATE PROCEDURE PA22()
BEGIN
	DECLARE X INT ;
    DECLARE Y INT;
    DECLARE Z INT;
    SELECT FIRST , SEC , THIRD 
    INTO X, Y, Z
    FROM T3INT
    LIMIT 1;
    IF  X+Y > Z AND Y+Z>X AND Z+X>Y 
    THEN 
		INSERT INTO TEMC VALUES(1,'VALID TRIANGLE');
    ELSE 
		INSERT INTO TEMC VALUES(2,'NOT A TRIANGLE');
    END IF;
END; //
DELIMITER ;

