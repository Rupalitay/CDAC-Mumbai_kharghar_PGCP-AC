4. Write a program that Selects from any table two character strings.  Your program should 
then determine if one character string exists inside another character string.   

DELIMITER //
CREATE PROCEDURE PC24()
BEGIN
	DECLARE X CHAR (40) ;
    DECLARE Y CHAR (40);
    SELECT SECOND INTO X
    FROM TEMC
    LIMIT 1 ;
    SELECT SECOND INTO Y
    FROM TEMC
    LIMIT 1 OFFSET 1 ;
    
    IF  X LIKE (CONCAT('%' ,Y,'%'))
    THEN 
		INSERT INTO TEMCC VALUES(X,Y,'STRING EXISTS');
    ELSE 
		INSERT INTO TEMCC VALUES(X,Y,'STRING NOT EXISTS ');
    END IF;
END; //
DELIMITER ;

mysql> CALL PC24();
