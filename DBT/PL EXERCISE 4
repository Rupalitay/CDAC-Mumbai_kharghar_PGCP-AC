

CREATE TABLE CUSTOMERSS
(
	METER_NUMBER VARCHAR(40),
    METER_TYPE CHAR(1),
    PREVIOUS_READING INT,
    CURRENT_READING INT,
    CUSTOMER_TYPE CHAR(1),
    LAST_BILL_PAYMENT CHAR(1)
);
-----------------------------------------------------------------
CREATE TABLE BILLTABL
(
	METER_NO VARCHAR(40),
    UNITS_USED INT,
    RATE FLOAT,
    AMOUNT FLOAT,
    SURCHARGE FLOAT,
    EXCISE FLOAT,
    NET FLOAT
);
----------------------------------------------------------------------
CREATE TABLE BILLT
(
	TOTAL_AMOUNT FLOAT,
    SURCHARGE FLOAT,
    EXCISE FLOAT,
    NET FLOAT
);
