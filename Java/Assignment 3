    Product(int productId, String name,double price,int quantity){
        this.productId = productId;
        this.name = name;
        this.price = price;
        this.quantity = quantity;
    }

    void priceUpdate(int updatedprice){
        if(updatedprice <= 0){
            System.out.println("Invalid update value");
        }
        else{
            price = updatedprice;
            System.out.println("Price updated");
        }
    }

    void priceUpdate(double discount, boolean ifdiscount){
        if(ifdiscount){
            price -=  price * discount/100;
            System.out.println("Price updated with discount");
        }
    }

    void updateStock(int quantity){
        this.quantity = quantity;
        System.out.println("Quantity updated");
    }

    double stockValue(){
        return price * quantity; 
    }

    void printDetails(){
        System.out.println("Product Id : " +this.productId);
        System.out.println("Product Name : " +this.name);
        System.out.println("Price : " +this.price);
        System.out.println("Quantity : " +this.price);
    }
}

