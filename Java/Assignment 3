import java.util.Scanner;
class Order{
    int orderId;
    String customerName;
    String []items;
    double []prices;

    static int totalOrders;

    Order(){}

    Order(int orderId,String customerName,String[] items,double[] prices){
        this.orderId = orderId;
        this.customerName = customerName;
        this.items = items;
        this.prices = prices;
        totalOrders++;
    }

    double calculateBill(){
        double total = 0;
        for(int i =0 ; i< prices.length;i++){
            total += prices[i] ;
        }
        return total;
    }

    double applyGST(double total){
        return total+(total*0.18);
    }

    void displayBill(){
        System.out.println("-------------------Final Bill-----------------------------");
        System.out.println("Order Id : " +orderId);
        System.out.println("Customer Name : " +customerName);

        for(int i = 0 ; i< items.length ; i++){
            System.out.println("Item : " +items[i]+" Prices : Rs. " +prices[i]);
        }

        double total = calculateBill();
        double finalBill = applyGST(total);
        System.out.println("Total : " +total);
        System.out.println("Total Amount with 18% GST : " +finalBill);
        System.out.println("---------------------------------------------------");

    }

}

