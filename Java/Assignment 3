import java.util.Scanner;

class Student{
    int rollNo;
    String name, phoneNo, email;
    int sub1, sub2, sub3, sub4, sub5, sub6;
    double total , avg;

    Student(){

    }

    Student(int rollNo, String name, String phoneNo, String email, int sub1,int  sub2,int sub3,int sub4,int sub5,int sub6 ){
        this.rollNo = rollNo;
        this.name = name;
        this.phoneNo = phoneNo;
        this.email = email;
        this.sub1 = sub1;
        this.sub2 = sub2;
        this.sub3 = sub3;
        this.sub4 = sub4;
        this.sub5 = sub5;
        this.sub6 = sub6;
    }

    double calculatetotal(){
        total = this.sub1 + this.sub2 + this.sub3 + this.sub4 + this.sub5 +this.sub6;
        return total;
    }
    double calculateAvg(){
        avg = total / 6 ;
        return avg;
    }

}
class CollegeERP{
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);
        
        int noOfStudents;

        System.out.println("Enter Number of Student : ");
        noOfStudents = sc.nextInt();

        Student stud[] = new Student[noOfStudents];//will create the array of Student class with reference stud

        for(int i = 0; i<noOfStudents ; i++){
            System.out.println("Enter Student "+(i+1)+" details: ");
            System.out.println("Enter Rollno : ");
            int rollNo = sc.nextInt();
            sc.nextLine();
            System.out.println("Enter Name : ");
            String name = sc.nextLine();
            System.out.println("Enter Phone Number : ");
            String phoneNo = sc.nextLine();
            System.out.println("Enter Email Id : ");
            String email = sc.nextLine();
            System.out.println("Enter sub1 marks : ");
            int sub1 = sc.nextInt();
            System.out.println("Enter sub2 marks : ");
            int sub2 = sc.nextInt();
            System.out.println("Enter sub3 marks : ");
            int sub3 = sc.nextInt();
            System.out.println("Enter sub4 marks : ");
            int sub4 = sc.nextInt();
            System.out.println("Enter sub5 marks : ");
            int sub5 = sc.nextInt();
            System.out.println("Enter sub6 marks : ");
            int sub6 = sc.nextInt();
           
            stud[i] = new Student(rollNo ,name , phoneNo , email ,sub1, sub2, sub3, sub4, sub5, sub6);
        }

        System.out.println("--------------------------------------------------------Student Report---------------------------------------------------");

        System.out.printf("%-10s %-20s %-12s %-30s %-5s %-5s %-5s %-5s %-5s %-5s %-5s %-5s ",
                        "RollNo","Name","Phone No","Email Id","Sub1","Sub2","Sbu3","Sub4","Sub5","Sub6","Total","Avg" );

        for(int i = 0 ; i<noOfStudents ;i++){
            System.out.printf("\n%-10s %-20s %-12s %-30s %-5s %-5s %-5s %-5s %-5s %-5s %-5.2f %-5.2f ",
                                                                stud[i].rollNo,
                                                                stud[i].name,
                                                                stud[i].phoneNo,
                                                                stud[i].email,
                                                                stud[i].sub1,
                                                                stud[i].sub2,
                                                                stud[i].sub3,
                                                                stud[i].sub4,
                                                                stud[i].sub5,
                                                                stud[i].sub6,
                                                                stud[i].calculatetotal(),
                                                                stud[i].calculateAvg() );
        }
         System.out.println();
        System.out.println("-----------------------------------------------------------------------------------------------------------------------------");

        sc.close();
    }
}

