        this.bookId = bookId;
        this.title = title;
        this.author = author;
        this.status = status;
        totalBooks++;
    }


    void issueBook(){
        if(status == true){
            status = false;
            System.out.println("Book issued of Title : " +this.title);
        }
        else{
            System.out.println("Book is Unavaliable of Title : " +this.title);
        }

    }

    void returnBook(){
        status = true;
        System.out.println("Book Returned of Title : " +this.title);
    }

    void dispaly(){
        System.out.println("Book Id " +this.bookId+ " Title " +this.title+ " By "+this.author+ " is"+((status == true) ? " Not": "")+" Avaliable " );
    }

}
