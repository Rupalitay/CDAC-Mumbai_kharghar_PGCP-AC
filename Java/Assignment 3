import java.util.Scanner;

class BankAccount{
    int accountNo;
    String holderName;
    double balance;
    String mode = "Cash";

    BankAccount(){}

    BankAccount(int accountNo, String holderName, double balance){
        this.accountNo = accountNo;
        this.holderName = holderName;
        this.balance = balance;
    }

    void depositMoney(double deposit){
        if(deposit <= 0){
            System.out.println("---Invalid Deposit Amount---");
        }
        else{
                this.balance += deposit; 
        }

    }
    
    void depositMoney(double deposit, String mode){
        this.mode = mode;
        if(deposit <= 0){
            System.out.println("---Invalid Deposit Amount---");
        }
        else{
                this.balance += deposit; 
        }

    }


    void withdrawMoney(double withdraw){
        if(withdraw >= balance || withdraw == 0){
            System.out.println("---Balance Insufficient---");
        }
        
        else{
            this.balance -= withdraw;
        }
    }

      void displayDetails(){
        System.out.println("Account Number : " + accountNo);
        System.out.println("Account Holder Name : " + holderName);
        System.out.println("Balance in Account : " + balance);
        System.out.println();
    } 
}
class BankingSystem{
    public static void main(String arg[]){
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter Numbers of Acounts : ");
        int noOfAccounts = sc.nextInt();

        BankAccount b[] = new BankAccount[noOfAccounts];
         for(int i = 0; i<noOfAccounts ; i++){
            System.out.println("Enter Account "+(i+1)+" details: ");
            System.out.println("Enter AcountNo : ");
            int accountNo = sc.nextInt();
            sc.nextLine();
            System.out.println("Enter Name : ");
            String name = sc.nextLine();
            System.out.println("Enter Balance : ");
            double balance = sc.nextDouble();
        
            b[i] = new BankAccount(accountNo, name, balance);
            int choice = 0; 

            do{
                
                System.out.println("\nEnter 1. to deposit in cash");
                System.out.println("Enter 2. to deposit in Online");
                System.out.println("Enter 3. to withdraw in cash");
                System.out.println("Enter choice");
                choice = sc.nextInt();

                switch(choice){
                    case 1: System.out.println("\nEnter Money to deposit in cash: ");
                            double cash = sc.nextDouble();
                            b[i].depositMoney(cash);
                            break;

                    case 2: System.out.println("\nEnter Money to deposit in Online: ");
                            double Online = sc.nextDouble();
                            b[i].depositMoney(Online,"Online");
                            break;

                    case 3: System.out.println("Enter Money to withdraw in cash: ");
                            double withdraw = sc.nextDouble();
                            b[i].withdrawMoney(withdraw);
                            break;

                    case 4: System.out.println("---Exiting------ ");break;

                    default : System.out.println("Invalid choice......"); break;
                }

               
            }while(choice != 4);
        
        }

        for(int i = 0; i<noOfAccounts ; i++){ 
                 b[i].displayDetails();
        }

    }
}
