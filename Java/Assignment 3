    Student(int studentId , String studentName){
        this.studentId = studentId;
        this.studentName = studentName;
    }

    void enrollCourse(Course c){
        if (count < enrollCourses.length){
            enrollCourses[count++] = c;
            System.out.println(studentName+" enrolled in "+c.name);
        }
        else{
            System.out.println("Enrolling limit exceed");
        }
    }

    void displayDetails(){
        System.out.println("Student ID : " + studentId+" Student Name : " + studentName);

        for(int i = 0 ; i < count ; i++){
            enrollCourses[i].printDetails();
        }
    }
}

class CourseManagementSystem{
    public static void main(String args[]){
        Course c = new Course(101,"C++",10000);
        Course c1 = new Course(102,"Java",15000);
        Course c2 = new Course(103,"DBT",8000);
        Course c3 = new Course(104,"DSA",12000);

        System.out.println("Total Courses : " + c3.totalCourses);

        Student s = new Student(1001, "Harry Smith");
        Student s1 = new Student(1003, "Garry Smith");
        Student s2 = new Student(1005, "Jay Smith");
        Student s3 = new Student(1006, "John Smith");

        s.enrollCourse(c);
        s.enrollCourse(c1);
        s.enrollCourse(c2);
        System.out.println();

        s1.enrollCourse(c1);
        s1.enrollCourse(c3);
        System.out.println();

        s2.enrollCourse(c);
        s2.enrollCourse(c2);
        System.out.println();

        s3.enrollCourse(c2);
        System.out.println();

        s.displayDetails();
        System.out.println();

        s1.displayDetails();
        System.out.println();

        s2.displayDetails();
        System.out.println();

        s3.displayDetails();
        System.out.println();

    }
}


