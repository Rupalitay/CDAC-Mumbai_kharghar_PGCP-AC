import java.util.Scanner;
class BusTicketBookingSystem{
    public static void main(String args[]){
        int noOfSeats[] = new int[10];
        int choice, seatNo;

        Scanner sc = new Scanner(System.in);

        do{
            System.out.println();
        
            System.out.println("-------Bus Booking System-----");
            System.out.println("Enter 1 to View Available Seats.");
            System.out.println("Enter 2 to Book a seat.");
            System.out.println("Enter 3 to Cancel a seat.");
            System.out.println("Enter 4 to Exit.");
            System.out.println();
            System.out.println("Enter the choice : ");
            choice = sc.nextInt();
            System.out.println();

            switch(choice){
                case 1 : System.out.println("---View Available And Booked seats---");
                            for(int i = 0 ; i < 10 ; i++){
                                if(noOfSeats[i] == 0)
                                    System.out.println((i+1) +" Seat is Available. ");
                                else    
                                    System.out.println((i+1) +" Seat is Booked. ");
                            }
                            break;

                case 2 : System.out.println("---Book a seat---");
                            System.out.println("Enter seat number to book(1-10)");
                            seatNo = sc.nextInt();
                            if(seatNo<1 || seatNo >10){
                                System.out.println("Invalid seatNo");
                            }
                            else if(noOfSeats[seatNo-1] == 1){
                                System.out.println("SeatNo "+ seatNo +" is already Booked");
                            }
                            else{
                                noOfSeats[seatNo-1] = 1;
                                System.out.println("SeatNo " + seatNo + " seat is Booked");
                            }
                            break;

                case 3 : System.out.println("---Cancel a Seat---");
                            System.out.println("Enter SeatNo to cancel a seat");
                            seatNo = sc.nextInt();
                            if(seatNo < 1 || seatNo > 10){
                                System.out.println("Invalid seatNo");
                            }
                            else if(noOfSeats[seatNo-1] == 0 ){
                                System.out.println("SeatNo "+seatNo+" is already avaliable");                            
                            }
                            else{
                                noOfSeats[seatNo-1] = 0;
                                System.out.println("SeatNo "+seatNo+" is cancelled");
                            }
                            break;

                case 4 : System.out.println("---Exiting---");
                            break;
                default : System.out.println("---Invalid choice---");
                            break;                                                
            }

            
        }while(choice != 4);

    }
}

