import java.util.Scanner;

class Employee{
    String employeeName;
    int empId;
    Double basicSalary ,hra, da, pf, gross , netSalary;

    void calculateNetSalary() {
        hra = 0.20 * basicSalary;
        da = 0.10 * basicSalary;
        pf = 0.08 * basicSalary;

        gross = basicSalary + hra + da;
        netSalary = gross - pf;
    }

}
class EmployeeSalarySlip{
    public static void main(String args[]){
        int noOfEmployees;

        Scanner sc = new Scanner(System.in);

        
        System.out.println("Enter Number of Employess: ");
        noOfEmployees = sc.nextInt();
        sc.nextLine();//Clear Buffer

        Employee E[]= new Employee[noOfEmployees];

        for(int i = 0; i < noOfEmployees ; i++){
            E[i] = new Employee();

            System.out.println("\nEmployee " + (i + 1));

            System.out.println("Enter Employee Name: ");
            E[i].employeeName = sc.nextLine();

            System.out.println("Enter Employee Id: ");
            E[i].empId = sc.nextInt();

            System.out.println("Enter Employee Basic Salary: ");
            E[i].basicSalary = sc.nextDouble();
            sc.nextLine();//clear buffer

            E[i].calculateNetSalary();

        }

        System.out.println("--------------------------------Salary Slip-------------------------------");
        System.out.printf("%-20s %-5s %-15s %-10s %-10s %-10s %-15s","Employee Name","Emp Id","BasicSalary","HRA","DA","PF","Net Salary");
