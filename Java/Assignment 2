                                        E[i].employeeName,
                                        E[i].empId,
                                        E[i].basicSalary,
                                        E[i].hra,
                                        E[i].da,
                                        E[i].pf,
                                        E[i].netSalary);
            System.out.println();
        }

        System.out.println("----------------------------------------------------------------------");

        sc.close();
    }
}
