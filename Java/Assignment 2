import java.util.Scanner;
class Bill{

    int consumerNo;
    int unitsConsumed;
    String customerName;
    double bill;
    double surcharge;

    Bill(){
        bill = 0.0;
        surcharge = 0.0;
    }

    void calculateBill(int unitsConsumed){
        if (unitsConsumed <= 100){
            bill = 5 * unitsConsumed;
        }
        else if (unitsConsumed >100 && unitsConsumed <= 200){
            bill = 7 * unitsConsumed;
        }
        else if (unitsConsumed > 200){
            bill = 10 * unitsConsumed;
        }

        if(bill > 1500){
            surcharge = (5* bill)/100;
            bill += surcharge; 
        }

    }

    void display(){
        System.out.println(" Consmer no: " + consumerNo);
        System.out.println(" Units Consumed: " + unitsConsumed);
        System.out.println(" Customer Name: " + customerName);
        System.out.println(" Bill Amount : " + bill);
        System.out.println(" Surcharge : " + surcharge);

    }

}

class ElectricityBillCal{
    
    public static void main(String args[]){
        Bill E = new Bill();
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter consmer no: ");
        E.consumerNo = sc.nextInt();
        System.out.println("Enter units consumed: ");
        E.unitsConsumed = sc.nextInt();
        sc.nextLine();
        System.out.println("Enter Customer Name: ");
        E.customerName = sc.nextLine();
        
        E.calculateBill(E.unitsConsumed);

        E.display();
    
    } 
}

