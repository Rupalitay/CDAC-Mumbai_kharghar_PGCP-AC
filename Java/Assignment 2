import java.util.Scanner;

class DailyExpenseTracker{
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);
        double expense[] = new double[7];
        double totalWeeklyExpense = 0.0, averageExpense = 0.0, highestExpense = 0.0, lowestExpense = 0.0;
        System.out.println("-----Enter the daily Expense ----");
        for(int i = 0; i<7 ; i++){
            System.out.println("Enter the day"+ (i+1)+" Expense :");
            expense[i] = sc.nextDouble();
        }
        
        highestExpense = expense[0];
        lowestExpense = expense[0];
        for(int i =0 ; i<7 ; i++){
            
            totalWeeklyExpense += expense[i];
            lowestExpense = expense[i] < lowestExpense ? expense[i] : lowestExpense;
            highestExpense = expense[i] > highestExpense ? expense[i]:highestExpense;
        }

        averageExpense = totalWeeklyExpense / 7;

        System.out.println();
        System.out.println("------------Daily Expense -------------");
        System.out.printf("Total Weekly Expense : %-10.2f " , totalWeeklyExpense);
