class ScopeDemonstrationProgram{
    // Class level variable (accessible everywhere in class)
    static int classVar = 100;

    public static void main(String[] args) {

        // Variable inside method
        int methodVar = 10;
        System.out.println("Method Variable: " + methodVar);

        //  Variable inside loop
        for (int i = 0; i < 3; i++) {
            int loopVar = i * 2;
            System.out.println("Loop Variable: " + loopVar);
        }

        // ERROR: loopVar not accessible here
        // System.out.println(loopVar);

        // Variable inside block
        if (true) {
            int blockVar = 50;
            System.out.println("Block Variable: " + blockVar);
        }

        // ERROR: blockVar not accessible here
        // System.out.println(blockVar);

        // Accessing class variable
        System.out.println("Class Variable: " + classVar);
    }
