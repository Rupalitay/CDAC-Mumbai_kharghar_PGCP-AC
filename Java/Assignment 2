 import java.util.Scanner;

class StudentResult{
    //declaration of data members
    int roll;
    String name;
    
    double total = 0.0;
    double avg = 0.0;
    double percentage = 0.0;
    String grade;

    double submarks[] = new double[5];


    StudentResult(){
        
    }

    StudentResult(int roll, String name){

        this.roll = roll;
        this.name = name;
        System.out.println("Enter 5 subjects marks");
        for (int i = 0 ; i < 5 ; i++){
            this.submarks[i] = submarks[i];
        }
       
    }
    

    void calculateTotal(){
        for (int i = 0 ; i < 5 ; i++){
            total += submarks[i] ;
        }

        avg = total / 5;

        percentage = avg ;

        grade = (percentage >= 90) ? "A" :
                (percentage >= 75) ? "B" :
                (percentage >= 60) ? "C" :
                (percentage >= 40) ? "D" :
