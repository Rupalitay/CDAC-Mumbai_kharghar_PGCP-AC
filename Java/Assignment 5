class ElectronicsObjects{
    int electId;
    String name;
    String brand;
    double price;

    ElectronicsObjects(){}

    ElectronicsObjects(int electId,String name,String brand,double price){
        this.electId = electId;
        this.name = name;
        this.brand = brand;
        this.price = price;
    }

    void electDisplay(){
        System.out.println("Electronics ID : "+this.electId+
        ", Name : "+this.name+
        ", Brand : " +this.brand+
        ", Price : "+this.price);
    }
}

class ClothingObjects{
    int clothId;
    String name;
    String brand;
    String size;
    double price;

    ClothingObjects(){}

    ClothingObjects(int clothId,String name,String brand,String size,double price){
        this.clothId = clothId;
        this.name = name;
        this.brand = brand;
        this.size = size;
        this.price = price;
