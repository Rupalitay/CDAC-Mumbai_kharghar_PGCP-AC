import java.util.Arrays;
import java.util.List;

class FinanCal<T>{

    public static <T extends Number> double calculateSum(List<T> obj ){
        double res = 0;
        for(Number item : obj){
            res += item.doubleValue();//convert item to double;
        }
        return res;
    }
    public static <T extends Number> double calculateAvg(List<T> obj ){
        if(obj.isEmpty()){
            return 0;
        }
        double sum = calculateSum(obj);
              
        return sum / obj.size();
    }
}
class FinancialCalculator{
    public static void main(String args[]){
        FinanCal <Integer> trans = new FinanCal<>();

        List <Integer> transaction = Arrays.asList(5600,2000,230,520,4510,561);
        Integer sumt = (int)trans.calculateSum(transaction);
        System.out.println("Sum of transaction is : "+ sumt);

        double avg = (double)trans.calculateAvg(transaction);
        System.out.printf("Average of transaction is : %.2f",avg);


        List<Double> salary = Arrays.asList(20000.56,5000.45,80000.56,40000.45,20566.56);
        System.out.println("Sum of Salary Data is : "+FinanCal.calculateSum(salary) );
        System.out.println("Average of Salary Data is : "+FinanCal.calculateAvg(salary) );
    
    }
}

