import java.util.*;
class Payment{
    int paymentId;
    double amount;

    Payment(){}

    Payment(int paymentId,double amount){
        this.paymentId = paymentId;
        this.amount = amount;
    }
    void displayPayment(){
        System.out.println("Payment Id : "+this.paymentId+", Amount : "+this.amount);
    }
}

class CreditCardPayment extends Payment{
    String cardNo;
    int cvv;

    CreditCardPayment(){}

    CreditCardPayment(int paymentId,double amount,String cardNo,int cvv){
        super(paymentId, amount);
        this.cardNo = cardNo;
        this.cvv = cvv;
    }
    void displayPayment(){
        System.out.println("Payment Id : "+this.paymentId+
                            ", Amount : "+this.amount+
                            ", CardNumber : "+this.cardNo+
                            ",CVV : "+this.cvv);
    }
}

class UPIPayment extends Payment{
    String upiId;

    UPIPayment(){}

    UPIPayment(int paymentId,double amount,String upiId){
        super(paymentId, amount);
        this.upiId = upiId;
    }
    void displayPayment(){
        System.out.println("Payment Id : "+this.paymentId+
                            ", Amount : "+this.amount+
                            ", UPI Id : "+this.upiId);
    }
}

class PaymentDetails <T extends Payment>{
    public static void displayAllDetails(List<? extends Payment> list){
        for(Payment p : list){
            p.displayPayment();
        }
    }
}

