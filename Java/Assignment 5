import java.util.*;

class Generator<T>{

    Generator(){}

    void generateReport(T[] data){
        System.out.println("---------Report-------");
        for(T item : data){
            System.out.println(item);
        }
        System.out.println("-----------------------");
    }

    void generateRep(List<T> data){
        System.out.println("---------Report-------");
        Iterator<T> it = data.iterator();
        while(it.hasNext()){
            System.out.println(it.next());
        }  
        System.out.println("-----------------------");
    }

    
}
class ReportGenerator{
    public static void main(String args[]){
        String name[] = {"Rahul" , "Arun","Karan","Kiran","Girish"};
        Generator<String> gen = new Generator<String>() ;
        System.out.println("Report of Employees Names: ");
        gen.generateReport(name);

        List<Integer> productId = Arrays.asList(1023,1246,1564,1054,1562,1021,1027);
        Generator<Integer> gen1 = new Generator<Integer>() ;
        System.out.println("Report of Products ID: ");
        gen1.generateRep(productId);

        Double saleFigure[] = {566.56,456.5,12.9,4564.556,451.90,564.58};
        Generator<Double> gen2 = new Generator<Double>();
        System.out.println("Report of Sale Figures: ");
        gen2.generateReport(saleFigure); 

    }
}

