        ", Size : "+this.size+
        ", Price : "+this.price);
    }
}
class Inventory<T>{
    T product;

    void add(T pro){
        this.product = pro;
    }

    T retrieve(){
        return product;
    }

    void productDetails(){
        System.out.println(this.product);
    }

    public String toString(){
        return product.toString();
    }
}
class Ecommerce{
    public static void main(String args[]){
        ElectronicsObjects e = new ElectronicsObjects(1001,"Laptop","HP",90000);
        Inventory<ElectronicsObjects> eo = new Inventory<ElectronicsObjects>();
        eo.add(e);
        eo.retrieve();
        eo.productDetails();
        e.electDisplay();

        ElectronicsObjects e1 = new ElectronicsObjects(1031,"Moblie","Samsung",90000);
        Inventory<ElectronicsObjects> eo1= new Inventory<ElectronicsObjects>();
        eo1.add(e);
        eo1.retrieve();
        eo1.productDetails();
        e1.electDisplay();

        ClothingObjects c = new ClothingObjects(102,"Shirt","Tokyo Talkies","M",5000);
        Inventory<ClothingObjects> ic = new Inventory<ClothingObjects>();
        ic.add(c);
        ic.productDetails();
        c.clothDisplay();
        
    }
}

