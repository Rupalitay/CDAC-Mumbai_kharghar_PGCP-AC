class Inventory<T>{
    T product;

    void add(T pro){
        this.product = pro;
    }

    T retrieve(){
        return product;
    }

    void productDetails(){
        System.out.println(this.product);
    }

    public String toString(){
        return product.toString();
    }
}
class Ecommerce{
    public static void main(String args[]){
        ElectronicsObjects e = new ElectronicsObjects(1001,"Laptop","HP",90000);
